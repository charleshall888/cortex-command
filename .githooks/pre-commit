#!/bin/bash
# .githooks/pre-commit — policy-aware dual-source drift enforcement
#
# Five phases:
#   1. Validate every plugins/*/.claude-plugin/plugin.json has a non-empty
#      .name field, and fail closed if any discovered plugin dir is not
#      classified in BUILD_OUTPUT_PLUGINS or HAND_MAINTAINED_PLUGINS.
#   1.5. When staged paths match the parity trigger pattern (skills/, bin/cortex-,
#      justfile, bin/.parity-exceptions.md, CLAUDE.md, cortex/requirements/, tests/,
#      hooks/cortex-, claude/hooks/cortex-), run the parity linter against
#      the staged blob view to enforce SKILL.md-to-bin parity.
#   2. Decide whether a build is needed based on staged paths. Build is
#      needed when any staged path is a top-level source (skills/, bin/cortex-,
#      hooks/cortex-, claude/hooks/cortex-) or under a build-output plugin
#      tree. The pattern must cover every source `just build-plugin` reads —
#      out-of-sync triggers cause silent mirror drift.
#   3. When a build is needed, run `just build-plugin` to regenerate all
#      build-output plugin trees from top-level sources.
#   4. For each build-output plugin, run `git diff --quiet plugins/$p/` to
#      detect drift between the freshly-built working tree and the index.
#
# Enable with:   just setup-githooks
# Bypass once:   git commit --no-verify   (discouraged)

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# -----------------------------------------------------------------------------
# Phase 1 — Name validation and classification guard
# -----------------------------------------------------------------------------
# Populate BO/HM from helper recipes. `mapfile -t` is the natural idiom but is
# unavailable in bash 3.2 (macOS system bash); use read-loop to remain
# compatible with the spec's `#!/bin/bash` shebang constraint.
BO=()
while IFS= read -r line; do
    [ -n "$line" ] && BO+=("$line")
done < <(just _list-build-output-plugins)
HM=()
while IFS= read -r line; do
    [ -n "$line" ] && HM+=("$line")
done < <(just _list-hand-maintained-plugins)

shopt -s nullglob
for pj in plugins/*/.claude-plugin/plugin.json; do
    plugin_dir="${pj#plugins/}"
    plugin_dir="${plugin_dir%%/*}"

    if ! jq -e '.name | length > 0' "$pj" >/dev/null 2>&1; then
        echo "pre-commit: $pj missing non-empty 'name' field." >&2
        exit 1
    fi

    classified=0
    for p in "${BO[@]}"; do
        if [ "$p" = "$plugin_dir" ]; then classified=1; break; fi
    done
    if [ "$classified" -eq 0 ]; then
        for p in "${HM[@]}"; do
            if [ "$p" = "$plugin_dir" ]; then classified=1; break; fi
        done
    fi
    if [ "$classified" -eq 0 ]; then
        echo "pre-commit: plugin '$plugin_dir' not classified (BUILD_OUTPUT_PLUGINS or HAND_MAINTAINED_PLUGINS)." >&2
        exit 1
    fi
done
shopt -u nullglob

# -----------------------------------------------------------------------------
# Phase 1.5 — SKILL.md-to-bin parity enforcement
# -----------------------------------------------------------------------------
# When any staged path matches the parity trigger pattern, invoke the parity
# linter against the staged blob view. The linter exits non-zero on any
# violation; propagate that exit code so the commit is blocked.
parity_triggered=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        skills/*|bin/cortex-*|justfile|bin/.parity-exceptions.md|CLAUDE.md|cortex/requirements/*|tests/*|hooks/cortex-*|claude/hooks/cortex-*)
            parity_triggered=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMRD)

if [ "$parity_triggered" -eq 1 ]; then
    if ! just check-parity --staged; then
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 1.55 — Skill-prose to CLI argparse contract enforcement
# -----------------------------------------------------------------------------
# When any staged path matches the contract scan corpus (skills/, hooks/,
# justfile, docs/, tests/, CLAUDE.md, cortex/requirements/), invoke the
# contract linter against the staged blob view. The linter exits non-zero on
# any argparse drift between skill prose and CLI argument declarations;
# propagate that exit code so the commit is blocked.
contract_triggered=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        skills/*|hooks/*|justfile|docs/*|tests/*|CLAUDE.md|cortex/requirements/*)
            contract_triggered=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "$contract_triggered" -eq 1 ]; then
    if ! just check-contract --staged; then
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 1.6 — bin/cortex-* shim presence enforcement
# -----------------------------------------------------------------------------
# When any staged path matches ^bin/cortex-, invoke the aggregator's
# --check-shims to verify every bin/cortex-* (except the helper and aggregator
# themselves) has the cortex-log-invocation shim line in its first 50 lines.
# The aggregator's stderr (one missing-script basename per line) reaches the user.
shim_triggered=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        bin/cortex-*)
            shim_triggered=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "$shim_triggered" -eq 1 ]; then
    if ! bin/cortex-invocation-report --check-shims; then
        echo "pre-commit: bin/cortex-* shim line missing — add the cortex-log-invocation shim line to each script listed above." >&2
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 1.7 — backlog entry-point telemetry-call enforcement
# -----------------------------------------------------------------------------
# When any staged path is one of the four cortex_command/backlog/<mod>.py
# entry-point modules, invoke --check-entry-points to verify the first
# statement of each def main() is _telemetry.log_invocation(...). Catches
# regressions where an entry-point is added without wiring telemetry,
# preserving byte-equivalence with bin/cortex-log-invocation.
entry_points_triggered=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        cortex_command/backlog/update_item.py|cortex_command/backlog/create_item.py|cortex_command/backlog/generate_index.py|cortex_command/backlog/build_epic_map.py|cortex_command/backlog/ready.py|cortex_command/overnight/complete_morning_review_session.py|cortex_command/lifecycle/branch_mode_cli.py|cortex_command/lifecycle/picker_decision_cli.py|cortex_command/critical_review/resolve_feature_cli.py|cortex_command/critical_review/write_residue_cli.py|cortex_command/backlog/_telemetry.py)
            entry_points_triggered=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "$entry_points_triggered" -eq 1 ]; then
    if ! bin/cortex-invocation-report --check-entry-points; then
        echo "pre-commit: backlog entry-point module's def main() must begin with _telemetry.log_invocation(...) — fix each module listed above." >&2
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 1.8 — Events-registry enforcement
# -----------------------------------------------------------------------------
# When any staged path matches the events-registry trigger pattern, invoke the
# registry checker against the staged blob view. The checker exits non-zero
# when a skill prompt or overnight prompt emits an event name that is not
# present in bin/.events-registry.md; propagate that exit code so the commit
# is blocked. Python sources are intentionally not in the trigger set —
# backend-only commits do not invoke this phase.
events_registry_triggered=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        skills/*|cortex_command/overnight/prompts/*|bin/cortex-check-events-registry|bin/.events-registry.md)
            events_registry_triggered=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "$events_registry_triggered" -eq 1 ]; then
    if ! just check-events-registry; then
        echo "pre-commit: events-registry check failed — see bin/.events-registry.md and the script's error message above." >&2
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 1.85 — Prescriptive-prose scanner (LEX-1, R6/R7)
# -----------------------------------------------------------------------------
# When any staged path matches skill prose or backlog ticket bodies, invoke
# the prescriptive-prose scanner against the staged blob view. The scanner
# exits non-zero when a forbidden section (## Role, ## Integration, ## Edges)
# contains a path:line citation, §N/RN section-index citation, or a fenced
# code block of ≥2 non-empty lines. Touch points is exempt. Runs AFTER
# cortex-check-parity (Phase 1.5) and cortex-check-events-registry (Phase 1.8)
# so infrastructure-level violations surface first.
prescriptive_prose_triggered=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        skills/*|cortex/backlog/*.md|bin/cortex-check-prescriptive-prose)
            prescriptive_prose_triggered=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "$prescriptive_prose_triggered" -eq 1 ]; then
    if ! just check-prescriptive-prose; then
        echo "pre-commit: prescriptive-prose check failed — move path:line/§N citations and multi-line code blocks into the ## Touch points section of the ticket body." >&2
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 1.9 — Path-hardcoding scanner (#203)
# -----------------------------------------------------------------------------
# When any staged path matches the path-hardcoding trigger pattern, invoke the
# gate against the staged blob view. The gate exits non-zero when a Python
# source under cortex_command/ or a cortex-* script in bin/, hooks/, or
# claude/hooks/ contains a bare-prefix path literal (lifecycle/, backlog/,
# research/, requirements/) without a corresponding allowlist entry. Prevents
# silent regression to the pre-#202 layout in any new code.
path_hardcoding_triggered=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        cortex_command/*.py|cortex_command/**/*.py|bin/cortex-*|hooks/cortex-*|claude/hooks/cortex-*|bin/.path-hardcoding-allowlist.md)
            path_hardcoding_triggered=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "$path_hardcoding_triggered" -eq 1 ]; then
    if ! just check-path-hardcoding; then
        echo "pre-commit: path-hardcoding check failed — replace bare-prefix literals with Path(\"cortex/<prefix>\") style, or add an entry to bin/.path-hardcoding-allowlist.md if the bare prefix is intentional." >&2
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 1.95 — install_guard byte-identity parity (R11 / T8)
# -----------------------------------------------------------------------------
# When any staged path is the canonical install_guard, the vendored sibling, or
# the sync recipe itself, run `just sync-install-guard --check` to verify the
# vendored sibling at plugins/cortex-overnight/install_guard.py is byte-identical
# to the regenerated artifact from cortex_command/install_guard.py. Without this
# gate, an autoformatter pass on the canonical can silently drift the sibling
# and break the plugin's stdlib-only in-flight guard.
install_guard_triggered=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        cortex_command/install_guard.py|plugins/cortex-overnight/install_guard.py|justfile)
            install_guard_triggered=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "$install_guard_triggered" -eq 1 ]; then
    if ! just sync-install-guard --check; then
        echo "pre-commit: install_guard parity failed — run 'just sync-install-guard' and stage plugins/cortex-overnight/install_guard.py." >&2
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 1.96 — cli_pin.py structural integrity (R8)
# -----------------------------------------------------------------------------
# When the canonical CLI pin sibling is staged, verify its AST contains only a
# docstring (optional) and a single CLI_PIN = (tag, schema) 2-tuple assignment.
# Reject third-party imports, function/class definitions, top-level calls, or
# any tuple arity other than 2. The hook layer imports cli_pin.py without
# invoking server.py's side effects, so this guard locks in that invariant.
cli_pin_triggered=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        plugins/cortex-overnight/cli_pin.py)
            cli_pin_triggered=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "$cli_pin_triggered" -eq 1 ]; then
    if ! python3 - <<'PYEOF'
import ast
import sys
from pathlib import Path

TARGET = Path("plugins/cortex-overnight/cli_pin.py")

try:
    source = TARGET.read_text(encoding="utf-8")
except OSError as exc:
    print(f"pre-commit: cannot read {TARGET}: {exc}", file=sys.stderr)
    sys.exit(1)

try:
    tree = ast.parse(source, filename=str(TARGET))
except SyntaxError as exc:
    print(f"pre-commit: {TARGET} failed to parse: {exc}", file=sys.stderr)
    sys.exit(1)

seen_assign = False
for node in tree.body:
    # Allow a leading docstring: ast.Expr wrapping an ast.Constant string.
    if (
        isinstance(node, ast.Expr)
        and isinstance(node.value, ast.Constant)
        and isinstance(node.value.value, str)
    ):
        continue
    # Allow exactly one top-level assignment: CLI_PIN = (<tag>, <schema>).
    if isinstance(node, ast.Assign):
        if len(node.targets) != 1 or not (
            isinstance(node.targets[0], ast.Name)
            and node.targets[0].id == "CLI_PIN"
        ):
            print(
                f"pre-commit: {TARGET} line {node.lineno}: only `CLI_PIN = (...)` "
                "is allowed at module top level.",
                file=sys.stderr,
            )
            sys.exit(1)
        if not isinstance(node.value, ast.Tuple):
            print(
                f"pre-commit: {TARGET} line {node.lineno}: CLI_PIN must be a tuple literal.",
                file=sys.stderr,
            )
            sys.exit(1)
        if len(node.value.elts) != 2:
            print(
                f"pre-commit: {TARGET} line {node.lineno}: CLI_PIN tuple must have "
                f"exactly 2 elements (got {len(node.value.elts)}).",
                file=sys.stderr,
            )
            sys.exit(1)
        if seen_assign:
            print(
                f"pre-commit: {TARGET} line {node.lineno}: only one CLI_PIN "
                "assignment is allowed.",
                file=sys.stderr,
            )
            sys.exit(1)
        seen_assign = True
        continue
    # Anything else — Import, ImportFrom, FunctionDef, ClassDef, Expr(Call), If,
    # For, With, Try, AnnAssign, AugAssign, etc. — is rejected.
    kind = type(node).__name__
    detail = ""
    if isinstance(node, (ast.Import, ast.ImportFrom)):
        names = ", ".join(
            (alias.name if isinstance(node, ast.Import) else f"{node.module or ''}.{alias.name}")
            for alias in node.names
        )
        detail = f" (import: {names})"
    print(
        f"pre-commit: {TARGET} line {node.lineno}: disallowed top-level "
        f"{kind}{detail}. Only a docstring and `CLI_PIN = (tag, schema)` are permitted.",
        file=sys.stderr,
    )
    sys.exit(1)

if not seen_assign:
    print(
        f"pre-commit: {TARGET}: missing required `CLI_PIN = (tag, schema)` assignment.",
        file=sys.stderr,
    )
    sys.exit(1)

sys.exit(0)
PYEOF
    then
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 2 — Short-circuit decision
# -----------------------------------------------------------------------------
staged=$(git diff --cached --name-only --diff-filter=ACMR)
BUILD_NEEDED=0

if echo "$staged" | grep -qE '^(skills/|bin/cortex-|hooks/cortex-|claude/hooks/cortex-)'; then
    BUILD_NEEDED=1
fi

if [ "$BUILD_NEEDED" -eq 0 ]; then
    while read -r p; do
        [ -z "$p" ] && continue
        if echo "$staged" | grep -qE "^plugins/$p/"; then
            BUILD_NEEDED=1
            break
        fi
    done < <(just _list-build-output-plugins)
fi

# -----------------------------------------------------------------------------
# Phase 3 — Conditional build
# -----------------------------------------------------------------------------
if [ "$BUILD_NEEDED" -eq 1 ]; then
    if ! just build-plugin >/dev/null 2>&1; then
        echo "pre-commit: 'just build-plugin' failed — cannot verify plugin tree." >&2
        just build-plugin >&2 || true
        exit 1
    fi
fi

# -----------------------------------------------------------------------------
# Phase 4 — Drift loop
# -----------------------------------------------------------------------------
drift_found=0
drift_report=""
for p in "${BO[@]}"; do
    # Skip build-output plugins that exist neither on disk nor in the index
    # (declared in policy but not yet materialized — no drift possible).
    if [ ! -d "plugins/$p" ] && ! git ls-files --error-unmatch -- "plugins/$p/" >/dev/null 2>&1; then
        continue
    fi
    if ! git diff --quiet -- "plugins/$p/"; then
        drift_found=1
        drift_report+="  plugin: $p"$'\n'
        while IFS= read -r line; do
            drift_report+="    $line"$'\n'
        done < <(git diff --name-only -- "plugins/$p/")
    fi
done

if [ "$drift_found" -eq 1 ]; then
    echo "pre-commit: dual-source drift detected in one or more build-output plugins." >&2
    echo "The following files differ from the freshly-built plugin tree:" >&2
    printf '%s' "$drift_report" >&2
    echo "" >&2
    echo "Fix: edit the top-level source (skills/, bin/cortex-*, hooks/cortex-validate-commit.sh)," >&2
    echo "     run 'just build-plugin', and stage the regenerated plugin files." >&2
    exit 1
fi

exit 0
