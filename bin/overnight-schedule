#!/usr/bin/env bash
# overnight-schedule — schedule an overnight run for a specific time.
#
# Usage: overnight-schedule <target-time> [state-path] [time-limit] [max-rounds] [tier]
#   Target time: HH:MM (24-hour local time) or YYYY-MM-DDTHH:MM (ISO 8601)
#   All args are positional. Do NOT use --flag=value syntax.
#
# Examples:
#   overnight-schedule 23:01
#   overnight-schedule 23:01 lifecycle/sessions/.../overnight-state.json
#   overnight-schedule 2026-04-10T23:01 lifecycle/sessions/.../overnight-state.json 8h 10 max_100

set -euo pipefail

SELF="$(realpath "${BASH_SOURCE[0]}")"

# ---------------------------------------------------------------------------
# Launch path (internal — called by tmux)
# ---------------------------------------------------------------------------
if [[ "${1:-}" == "__launch" ]]; then
    shift
    DELAY="$1"
    STATE_PATH="$2"
    TARGET_ISO="$3"
    shift 3
    OVERNIGHT_ARGS=("$@")

    caffeinate -i sleep "$DELAY"

    # Clear scheduled_start from state file
    if [[ -n "$STATE_PATH" && -f "$STATE_PATH" ]]; then
        python3 -c "
import json,sys,tempfile,os
p=sys.argv[1]
d=json.load(open(p))
d['scheduled_start']=None
fd,t=tempfile.mkstemp(dir=os.path.dirname(os.path.abspath(p)))
os.write(fd,(json.dumps(d,indent=2)+'\n').encode())
os.close(fd)
os.replace(t,os.path.abspath(p))
" "$STATE_PATH" 2>/dev/null || true
    fi

    exec overnight-start "${OVERNIGHT_ARGS[@]}"
fi

# ---------------------------------------------------------------------------
# Setup path (user-facing)
# ---------------------------------------------------------------------------

# Guard against flag-style args
if [[ "${1:-}" == --* || "${1:-}" == *=* ]]; then
    echo "Error: wrong arg format — use positional syntax:" >&2
    echo "  overnight-schedule <target-time> [state-path] [time-limit] [max-rounds] [tier]" >&2
    echo "  overnight-schedule 23:01 lifecycle/sessions/.../overnight-state.json" >&2
    exit 1
fi

# Require at least one argument
if [[ $# -lt 1 ]]; then
    echo "Usage: overnight-schedule <target-time> [state-path] [time-limit] [max-rounds] [tier]" >&2
    echo "" >&2
    echo "Target time formats:" >&2
    echo "  HH:MM              24-hour local time (e.g. 23:01)" >&2
    echo "  YYYY-MM-DDTHH:MM   ISO 8601 date+time (e.g. 2026-04-10T23:01)" >&2
    echo "" >&2
    echo "Examples:" >&2
    echo "  overnight-schedule 23:01" >&2
    echo "  overnight-schedule 23:01 lifecycle/sessions/.../overnight-state.json" >&2
    echo "  overnight-schedule 2026-04-10T23:01 lifecycle/sessions/.../overnight-state.json 8h 10 max_100" >&2
    exit 1
fi

TARGET_TIME="$1"
shift
OVERNIGHT_ARGS=("$@")

# ---------------------------------------------------------------------------
# Validate and parse target time
# ---------------------------------------------------------------------------
NOW_EPOCH=$(date +%s)

if [[ "$TARGET_TIME" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-2][0-9]:[0-5][0-9]$ ]]; then
    # ISO format: YYYY-MM-DDTHH:MM
    HOUR="${TARGET_TIME:11:2}"
    if (( 10#$HOUR > 23 )); then
        echo "Error: invalid hour '$HOUR' — must be 00-23" >&2
        exit 1
    fi
    DATE_STR="${TARGET_TIME/T/ }"
    TARGET_EPOCH=$(date -j -f "%Y-%m-%d %H:%M" "$DATE_STR" +%s 2>/dev/null) || {
        echo "Error: invalid date/time '$TARGET_TIME'" >&2
        exit 1
    }
    TARGET_ISO="$TARGET_TIME"

    if (( TARGET_EPOCH <= NOW_EPOCH )); then
        echo "Error: scheduled time is in the past" >&2
        exit 1
    fi

elif [[ "$TARGET_TIME" =~ ^[0-2][0-9]:[0-5][0-9]$ ]]; then
    # HH:MM format
    HOUR="${TARGET_TIME:0:2}"
    if (( 10#$HOUR > 23 )); then
        echo "Error: invalid hour '$HOUR' — must be 00-23" >&2
        exit 1
    fi
    TARGET_EPOCH=$(date -j -f "%H:%M" "$TARGET_TIME" +%s 2>/dev/null) || {
        echo "Error: invalid time '$TARGET_TIME'" >&2
        exit 1
    }

    if (( TARGET_EPOCH <= NOW_EPOCH )); then
        echo "Target time has passed today — scheduling for tomorrow."
        TARGET_EPOCH=$((TARGET_EPOCH + 86400))
    fi
    TARGET_ISO=$(date -r "$TARGET_EPOCH" "+%Y-%m-%dT%H:%M")

else
    echo "Error: invalid time format '$TARGET_TIME'" >&2
    echo "Expected HH:MM (e.g. 23:01) or YYYY-MM-DDTHH:MM (e.g. 2026-04-10T23:01)" >&2
    exit 1
fi

DELAY_SECONDS=$((TARGET_EPOCH - NOW_EPOCH))

# Validate delay is within 7 days
if (( DELAY_SECONDS > 604800 )); then
    echo "Error: scheduled time is more than 7 days away" >&2
    exit 1
fi

if (( DELAY_SECONDS <= 0 )); then
    echo "Error: computed delay is not positive — target time may be in the past" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Compute display values
# ---------------------------------------------------------------------------
TARGET_LOCAL=$(date -r "$TARGET_EPOCH" "+%H:%M")
TARGET_UTC=$(date -u -r "$TARGET_EPOCH" "+%H:%M UTC")
DELAY_HOURS=$((DELAY_SECONDS / 3600))
DELAY_MINUTES=$(( (DELAY_SECONDS % 3600) / 60 ))

# ---------------------------------------------------------------------------
# Write scheduled_start to state file
# ---------------------------------------------------------------------------
STATE_PATH="${OVERNIGHT_ARGS[0]:-}"

if [[ -n "$STATE_PATH" ]]; then
    if [[ -f "$STATE_PATH" ]]; then
        python3 -c "
import json,sys,tempfile,os
p=sys.argv[1]
d=json.load(open(p))
d['scheduled_start']=sys.argv[2]
fd,t=tempfile.mkstemp(dir=os.path.dirname(os.path.abspath(p)))
os.write(fd,(json.dumps(d,indent=2)+'\n').encode())
os.close(fd)
os.replace(t,os.path.abspath(p))
" "$STATE_PATH" "$TARGET_ISO" 2>/dev/null || echo "Warning: failed to write scheduled_start to state file — proceeding without observability" >&2
    else
        echo "Warning: state file not found — scheduled_start observability disabled" >&2
    fi
fi

# ---------------------------------------------------------------------------
# tmux session with collision avoidance
# ---------------------------------------------------------------------------
if ! command -v tmux &>/dev/null; then
    echo "tmux not found — cannot schedule in background" >&2
    exit 1
fi

SESSION="overnight-scheduled"
N=2
while tmux has-session -t "=$SESSION" 2>/dev/null; do
    SESSION="overnight-scheduled-$N"
    N=$((N + 1))
done

tmux new-session -d -s "$SESSION" \
    "$SELF __launch $DELAY_SECONDS $STATE_PATH $TARGET_ISO ${OVERNIGHT_ARGS[*]}"

# tmux new-session -d can report success even when the server failed to start
# (e.g., socket dir unwritable under a restrictive sandbox). Verify the session
# is actually live before telling the caller the run is scheduled.
if ! tmux has-session -t "=$SESSION" 2>/dev/null; then
    echo "Error: tmux reported success but session '$SESSION' is not live." >&2
    echo "Check tmux errors above — common cause: socket dir is not writable." >&2
    echo "Socket dir: \${TMUX_TMPDIR:-/tmp}/tmux-\$UID/" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Confirmation output
# ---------------------------------------------------------------------------
echo "Overnight run scheduled."
echo "  Scheduled for $TARGET_LOCAL local ($TARGET_UTC)"
echo "  Starting in ${DELAY_HOURS}h ${DELAY_MINUTES}m"
echo "  Attach: tmux attach -t $SESSION"
echo "  Cancel: tmux kill-session -t $SESSION"
