#!/bin/bash
if command -v cortex-log-invocation >/dev/null; then
  cortex-log-invocation "$0" "$@" || echo "cortex-log-invocation failed: $?" >&2
fi
set -euo pipefail

# Branch (a): packaged form — cortex_command.overnight.gc_demo_worktrees
if python3 -c "import cortex_command.overnight.gc_demo_worktrees" 2>/dev/null; then
    exec python3 -m cortex_command.overnight.gc_demo_worktrees "$@"
fi

# Branch (b): CORTEX_COMMAND_ROOT points at a cortex-command checkout
if [ -n "${CORTEX_COMMAND_ROOT:-}" ] \
    && grep -q '^name = "cortex-command"' "$CORTEX_COMMAND_ROOT/pyproject.toml" 2>/dev/null \
    && [ -f "$CORTEX_COMMAND_ROOT/cortex_command/overnight/gc_demo_worktrees.py" ]; then
    exec env PYTHONPATH="$CORTEX_COMMAND_ROOT:${PYTHONPATH:-}" python3 -m cortex_command.overnight.gc_demo_worktrees "$@"
fi

# Branch (c): not found
echo "cortex-morning-review-gc-demo-worktrees: cortex-command CLI not found — install cortex-core plugin or set CORTEX_COMMAND_ROOT" >&2
exit 2
