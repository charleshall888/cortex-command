#!/usr/bin/env python3
"""SKILL.md-to-bin parity linter.

Detects two failure modes for ``bin/cortex-*`` scripts:
- E002 drift: a SKILL.md/doc references a script name that no longer exists.
- W003 orphan: a deployed script has no wiring signal in any in-scope file.
- E001 invalid allowlist row: ``bin/.parity-exceptions.md`` row fails schema.
- W005 allowlist-superfluous: a script is allowlisted AND has wiring in scope.

Stdlib-only. Operates on ``os.getcwd()``. See cortex/lifecycle/ship-dr-5-... for the
full spec (R1–R18).
"""

import os, subprocess, sys; subprocess.run([os.path.join(os.path.dirname(os.path.realpath(__file__)), "cortex-log-invocation"), sys.argv[0], *sys.argv[1:]], check=False)

import argparse
import json
import os
import re
import subprocess
import sys
from dataclasses import dataclass
from enum import Enum
from pathlib import Path
from typing import Iterable

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

# R5(c): closed plugin list — sourced from justfile BUILD_OUTPUT_PLUGINS +
# HAND_MAINTAINED_PLUGINS. Drift between this constant and the justfile is
# detected by the ``plugin-list-matches-justfile`` self-test case.
PLUGIN_NAMES: frozenset[str] = frozenset(
    {
        "cortex-core",
        "cortex-overnight",
        "cortex-pr-review",
        "cortex-ui-extras",
        "cortex-dev-extras",
        "android-dev-extras",
    }
)

# R5(c) extension: reserved cortex-prefixed identifiers that are NOT bin
# scripts. Project name (``cortex-command``) and MCP server name
# (``cortex-overnight``) appear in fenced code blocks (e.g. ``claude mcp add
# cortex-overnight``) that cannot be path-qualified, so candidacy must be
# excluded by name. Future names require an explicit edit here — same
# intentional friction as PLUGIN_NAMES.
RESERVED_NON_BIN_NAMES: frozenset[str] = frozenset(
    {
        "cortex-command",
        "cortex-overnight",
        # $TMPDIR directory name in docs/overnight-operations.md prose (commit 0168dac);
        # not a deployable script, hence excluded from candidacy.
        "cortex-overnight-launch",
        # Per-spawn sandbox tempfile prefix (`<session_dir>/sandbox-settings/cortex-sandbox-*.json`)
        # documented in docs/internals/pipeline.md and docs/overnight-operations.md; the trailing
        # dash captures the token-regex tail. Not a deployable script.
        "cortex-sandbox-",
        # $TMPDIR-resident output/result file prefixes used by
        # `cortex_command/overnight/seatbelt_probe.py`; documented in
        # docs/overnight-operations.md prose. Not deployable bin scripts.
        "cortex-seatbelt-output-",
        "cortex-seatbelt-result-",
        # Same-repo worktree-root directory name introduced by the
        # `restore-worktree-root-env-prefix` lifecycle: the resolver default is
        # `$TMPDIR/cortex-worktrees/<feature>`. Referenced in docstrings, tests,
        # and prose throughout the codebase; not a deployable script.
        "cortex-worktrees",
        # Sentinel suffix used to mark cortex-registered worktree-root entries
        # in `~/.claude/settings.local.json::allowWrite` (entries take the
        # shape `<path>#cortex-worktree-root`). Introduced by the same lifecycle
        # above; replaces the prior fragile substring-match scheme. Not a script.
        "cortex-worktree-root",
    }
)

# R5(d): the linter's own filename — never a candidate.
SELF_REFERENCE = "cortex-check-parity"

# R7: scan-scope globs. Plugin-tree mirrors NOT scanned.
SCAN_GLOBS: tuple[str, ...] = (
    "CLAUDE.md",
    "claude/hooks/cortex-*.sh",
    "docs/**/*.md",
    "hooks/cortex-*.sh",
    "justfile",
    "cortex/requirements/**/*.md",
    "skills/**/*.md",
    "tests/**/*.py",
    "tests/**/*.sh",
)

# R8: allowlist file location.
ALLOWLIST_PATH = "bin/.parity-exceptions.md"

# R12(c/d): bare-python-m audit allowlist location.
BARE_PYTHON_M_ALLOWLIST_PATH = "bin/.audit-bare-python-m-allowlist.md"

# R12(c): paths scanned by --audit-bare-python-m-callsites (relative to repo root).
BARE_PYTHON_M_SCAN_PATHS: tuple[str, ...] = (
    "skills",
    "hooks",
    "claude",
    "bin",
    "docs",
    "justfile",
    "tests",
)

# Sandbox pre-flight gate (spec Req 17 / Task 12) ---------------------------
# Watched files whose staged diff hunks are scanned for sandbox-source patterns.
# Maps file path -> tuple of regex patterns (any match in a staged diff hunk
# fires the gate). The sandbox_settings module fires on ANY change (entire
# file is sandbox-source, so the pattern is r"" matching everything).
SANDBOX_WATCHED_FILES: dict[str, tuple[str, ...]] = {
    "cortex_command/pipeline/dispatch.py": (
        r"_load_project_settings",
        r"sandbox",
        r"SandboxSettings",
        r"build_sandbox",
        r"write_settings_tempfile",
    ),
    "cortex_command/overnight/runner.py": (
        r"_spawn_orchestrator",
        r"--settings",
        r"sandbox",
    ),
    "cortex_command/overnight/sandbox_settings.py": (
        # entire file is sandbox-source — any change fires the gate
        r".",
    ),
    "pyproject.toml": (
        r"claude-agent-sdk",
    ),
}

# Canonical preflight artifact location for the sandbox per-spawn epic.
PREFLIGHT_PATH = (
    "cortex/lifecycle/apply-per-spawn-sandboxfilesystemdenywrite-at-all-overnight-spawn-sites/preflight.md"
)

ALLOWED_CATEGORIES: frozenset[str] = frozenset(
    {"maintainer-only-tool", "library-internal", "deprecated-pending-removal"}
)

# R12(d): closed-enum categories for the bare-python-m allowlist.
BARE_PYTHON_M_ALLOWED_CATEGORIES: frozenset[str] = frozenset(
    {
        "module-execution-pathway-test",
        "document-content-invariant",
        "wrapper-script-r14-pending",
    }
)
FORBIDDEN_RATIONALE_LITERALS: frozenset[str] = frozenset(
    {"internal", "misc", "tbd", "n/a", "pending", "temporary"}
)

# R5(b): tokens suffixed with ``.sh`` are hooks — explicitly excluded.
# R5(a): non-bin path qualifiers immediately preceding the token.
NON_BIN_PATH_PREFIX_RE = re.compile(
    r"(?:hooks/|plugins/|claude/hooks/|\.claude/hooks/|/hooks/)"
    r"cortex-[a-z][a-z0-9-]*"
)

# Token regex (R5 base): ``cortex-[a-z][a-z0-9-]*``. Allowlist also accepts
# bare ``[a-z][a-z0-9-]*`` (no un-prefixed scripts ship in bin/ currently).
SCRIPT_NAME_RE = re.compile(r"^cortex-[a-z][a-z0-9-]*$")
LOOSE_SCRIPT_NAME_RE = re.compile(r"^[a-z][a-z0-9-]*$")
TOKEN_RE = re.compile(r"cortex-[a-z][a-z0-9-]*")
DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")


class Severity(Enum):
    ERROR = "error"
    WARNING = "warning"


@dataclass(frozen=True)
class Violation:
    path: str
    line: int
    col: int
    code: str
    message: str

    @property
    def severity(self) -> Severity:
        return Severity.ERROR if self.code.startswith("E") else Severity.WARNING

    def to_dict(self) -> dict[str, object]:
        return {
            "path": self.path,
            "line": self.line,
            "col": self.col,
            "code": self.code,
            "message": self.message,
        }

    def format_text(self) -> str:
        return f"{self.path}:{self.line}:{self.col}: {self.code} {self.message}"


@dataclass(frozen=True)
class AllowlistRow:
    script: str
    category: str
    rationale: str
    lifecycle_id: str
    added_date: str
    line: int


# ---------------------------------------------------------------------------
# Filesystem helpers
# ---------------------------------------------------------------------------


def _expand_glob(root: Path, glob: str) -> list[Path]:
    """Expand a single scan glob relative to ``root``."""
    if "*" in glob:
        return sorted(p for p in root.glob(glob) if p.is_file())
    p = root / glob
    return [p] if p.is_file() else []


def gather_scan_files(root: Path) -> list[Path]:
    """Return the set of files matching any R7 scan glob."""
    seen: set[Path] = set()
    out: list[Path] = []
    for glob in SCAN_GLOBS:
        for p in _expand_glob(root, glob):
            rp = p.resolve()
            if rp in seen:
                continue
            seen.add(rp)
            out.append(p)
    return sorted(out, key=lambda p: str(p))


def gather_entry_point_names(root: Path) -> set[str]:
    """Return ``[project.scripts]`` keys from ``pyproject.toml``.

    Empty set if the file is missing or unparseable. After
    ``uv tool install -e .`` runs, each key in this table becomes a
    console-script binary on PATH — i.e., a deployed command.
    """
    pyproject = root / "pyproject.toml"
    if not pyproject.is_file():
        return set()
    try:
        import tomllib

        with open(pyproject, "rb") as f:
            data = tomllib.load(f)
        scripts = data.get("project", {}).get("scripts", {})
        if isinstance(scripts, dict):
            return set(scripts.keys())
    except Exception:
        return set()
    return set()


def gather_deployed(root: Path) -> set[str]:
    """Deployed-command set = ``bin/`` exec files ∪ ``[project.scripts]`` keys.

    The ``bin/``-side reflects committed-tree wrapper scripts (a
    filesystem fact); the ``[project.scripts]``-side reflects
    entry-point binaries that ``uv tool install -e .`` generates (a
    declarative ``pyproject.toml`` fact). Both halves are valid sources
    of truth for "this repo claims to ship command X"; the linter's
    job is committed-source drift detection, which both halves serve.
    W005 (allowlist-superfluous) stays scoped to ``bin/``-discovered
    commands only — entry-point names are out of scope for the
    allowlist mechanism.
    """
    out: set[str] = set()
    bin_dir = root / "bin"
    if bin_dir.is_dir():
        for entry in os.scandir(bin_dir):
            if entry.name.startswith("."):
                continue
            if not (entry.is_file(follow_symlinks=True) or entry.is_symlink()):
                continue
            try:
                st = entry.stat(follow_symlinks=True)
            except OSError:
                continue
            if st.st_mode & 0o111:
                out.add(entry.name)
    out |= gather_entry_point_names(root)
    return out


# ---------------------------------------------------------------------------
# Allowlist parsing (R8)
# ---------------------------------------------------------------------------


def parse_allowlist(
    text: str, *, source_path: str = ALLOWLIST_PATH
) -> tuple[list[AllowlistRow], list[Violation]]:
    """Parse the allowlist markdown table.

    Returns valid rows + E001 violations for malformed rows.
    """
    rows: list[AllowlistRow] = []
    violations: list[Violation] = []

    in_table = False
    saw_header = False
    saw_separator = False
    for idx, line in enumerate(text.splitlines(), start=1):
        stripped = line.strip()
        if not stripped.startswith("|"):
            in_table = False
            saw_header = False
            saw_separator = False
            continue
        cells = [c.strip() for c in stripped.strip("|").split("|")]
        if not saw_header:
            # Match canonical header row.
            if [c.lower() for c in cells] == [
                "script",
                "category",
                "rationale",
                "lifecycle_id",
                "added_date",
            ]:
                saw_header = True
                in_table = True
            continue
        if not saw_separator:
            # Separator row like ``| --- | --- | --- | --- | --- |``.
            if all(set(c) <= set("-: ") and "-" in c for c in cells):
                saw_separator = True
                continue
            # Header without separator → reset state.
            saw_header = False
            in_table = False
            continue
        if not in_table:
            continue
        if len(cells) != 5:
            violations.append(
                Violation(
                    source_path,
                    idx,
                    1,
                    "E001",
                    f"invalid allowlist entry: expected 5 columns, got {len(cells)}",
                )
            )
            continue
        script_raw, category_raw, rationale_raw, lifecycle_raw, date_raw = cells
        script = script_raw.strip().strip("`").strip()
        category = category_raw.strip().strip("`").strip()
        rationale = rationale_raw.strip()
        lifecycle_id = lifecycle_raw.strip().strip("`").strip()
        added_date = date_raw.strip().strip("`").strip()

        reasons: list[str] = []
        if not (SCRIPT_NAME_RE.match(script) or LOOSE_SCRIPT_NAME_RE.match(script)):
            reasons.append(f"script {script!r} does not match name pattern")
        if category not in ALLOWED_CATEGORIES:
            reasons.append(
                f"category {category!r} not in "
                f"{{maintainer-only-tool, library-internal, deprecated-pending-removal}}"
            )
        rationale_trim = rationale.strip()
        if len(rationale_trim) < 30:
            reasons.append(
                f"rationale must be ≥30 chars after trim (got {len(rationale_trim)})"
            )
        if rationale_trim.lower() in FORBIDDEN_RATIONALE_LITERALS:
            reasons.append(
                f"rationale literal {rationale_trim!r} is on the forbidden list"
            )
        if not lifecycle_id:
            reasons.append("lifecycle_id is empty")
        if not DATE_RE.match(added_date):
            reasons.append(
                f"added_date {added_date!r} does not match YYYY-MM-DD"
            )

        if reasons:
            violations.append(
                Violation(
                    source_path,
                    idx,
                    1,
                    "E001",
                    "invalid allowlist entry: " + "; ".join(reasons),
                )
            )
            continue

        rows.append(
            AllowlistRow(
                script=script,
                category=category,
                rationale=rationale_trim,
                lifecycle_id=lifecycle_id,
                added_date=added_date,
                line=idx,
            )
        )

    return rows, violations


def load_allowlist(
    root: Path,
) -> tuple[list[AllowlistRow], list[Violation], bool]:
    """Load allowlist file. Returns (rows, violations, file_present).

    Missing file → empty list + no violations + present=False (R Edge Cases).
    Unreadable / malformed parse → caller treats as fatal (E000).
    """
    p = root / ALLOWLIST_PATH
    if not p.is_file():
        return [], [], False
    try:
        text = p.read_text(encoding="utf-8")
    except OSError as exc:
        raise RuntimeError(f"cannot read {ALLOWLIST_PATH}: {exc}") from exc
    rows, viol = parse_allowlist(text)
    return rows, viol, True


# ---------------------------------------------------------------------------
# Wiring detection (R4) + candidate filter (R5) + R6 narrowing
# ---------------------------------------------------------------------------


FENCED_CODE_RE = re.compile(r"```.*?```", re.DOTALL)
INLINE_CODE_RE = re.compile(r"`([^`\n]+)`")
PATH_QUALIFIED_RE = re.compile(r"bin/(cortex-[a-z][a-z0-9-]*)")
# Shell-command-invocation patterns. These match unambiguous invocation
# sites (uv run / command -v) regardless of file type — they're not
# narrative mentions but actual calls. Added by backlog 208 follow-up after
# the parity scanner missed these in justfile and hooks/*.sh.
SHELL_INVOCATION_RE = re.compile(
    r"\b(?:uv run|command -v)\s+(cortex-[a-z][a-z0-9-]*)"
)


def _strip_excluded_tokens(text: str) -> str:
    """Blank out R5(a) path-qualified non-bin contexts before token scanning."""
    return NON_BIN_PATH_PREFIX_RE.sub(
        lambda m: " " * len(m.group(0)), text
    )


def _collect_inline_code_tokens(text: str) -> set[str]:
    out: set[str] = set()
    for match in INLINE_CODE_RE.finditer(text):
        body = match.group(1).strip()
        # R5(b): exclude .sh suffix.
        if body.endswith(".sh"):
            continue
        # Strip any leading ``bin/`` for purposes of token extraction; the
        # path-qualified path still wires via PATH_QUALIFIED_RE as well.
        for m in TOKEN_RE.finditer(body):
            # R5(e): exclude tokens preceded immediately by ``.`` —
            # ``.cortex-init`` and ``.cortex-update.lock`` are file/marker
            # names, not script invocations.
            if m.start() > 0 and body[m.start() - 1] == ".":
                continue
            out.add(m.group(0))
    return out


def _collect_fenced_code_tokens(text: str) -> set[str]:
    out: set[str] = set()
    for match in FENCED_CODE_RE.finditer(text):
        block = match.group(0)
        # Apply R5(a) exclusion within the block.
        cleaned = _strip_excluded_tokens(block)
        # R5(b): drop tokens immediately followed by ``.sh``.
        for m in TOKEN_RE.finditer(cleaned):
            tok = m.group(0)
            tail = cleaned[m.end() : m.end() + 3]
            if tail.startswith(".sh"):
                continue
            # R5(e): exclude tokens preceded immediately by ``.``.
            if m.start() > 0 and cleaned[m.start() - 1] == ".":
                continue
            out.add(tok)
    return out


def _collect_path_qualified_tokens(text: str) -> set[str]:
    out: set[str] = set()
    for m in PATH_QUALIFIED_RE.finditer(text):
        out.add(m.group(1))
    return out


def _collect_shell_invocation_tokens(text: str) -> set[str]:
    """Tokens invoked via `uv run X` or `command -v X`.

    Both are unambiguous shell-command invocations. Detected regardless of
    file type (markdown narrative, justfile, .sh) since the form itself
    expresses intent to run the named script.
    """
    return {m.group(1) for m in SHELL_INVOCATION_RE.finditer(text)}


# --- R6: detect "flat enumeration" markdown table cells -----------------


def _table_only_tokens(text: str) -> set[str]:
    """Return tokens that only appear in flat-enumeration table columns.

    A column is flat-enumeration iff ≥2 rows contain a single ``cortex-X``
    token (after stripping whitespace and backticks). A token is "table-only"
    if every flat-enumeration column it appears in has no narrative-prose
    mention of the same token elsewhere in the file (path-qualified or
    inline-code mention).
    """
    lines = text.splitlines()
    # Group contiguous markdown table blocks.
    table_blocks: list[list[tuple[int, list[str]]]] = []  # list of [(line_idx, cells)]
    block: list[tuple[int, list[str]]] = []
    for idx, line in enumerate(lines):
        stripped = line.strip()
        if stripped.startswith("|"):
            cells = [c.strip() for c in stripped.strip("|").split("|")]
            block.append((idx, cells))
        else:
            if block:
                table_blocks.append(block)
                block = []
    if block:
        table_blocks.append(block)

    table_tokens_per_column: list[set[str]] = []
    for tb in table_blocks:
        if len(tb) < 3:
            continue  # need header + separator + ≥1 data
        # Skip header (first row) and separator (second row).
        data_rows = tb[2:]
        if not data_rows:
            continue
        # Determine column count from header.
        ncols = len(tb[0][1])
        for col_idx in range(ncols):
            col_cells: list[str] = []
            for _, cells in data_rows:
                if col_idx < len(cells):
                    col_cells.append(cells[col_idx])
            # Strip backticks and whitespace, check if cell is exactly a token.
            matches: list[str] = []
            non_token_cells = 0
            for cell in col_cells:
                cleaned = cell.strip().strip("`").strip()
                if SCRIPT_NAME_RE.match(cleaned):
                    matches.append(cleaned)
                elif cleaned:
                    non_token_cells += 1
            if len(matches) >= 2 and non_token_cells == 0:
                table_tokens_per_column.append(set(matches))

    if not table_tokens_per_column:
        return set()

    # For each candidate flat-enumeration token, check whether the same file
    # mentions it elsewhere (narrative — path-qualified or inline-code).
    table_tokens: set[str] = set()
    for col in table_tokens_per_column:
        table_tokens |= col

    if not table_tokens:
        return set()

    # Compute "narrative mentions" — text outside of any matching table block.
    table_line_set: set[int] = set()
    for tb in table_blocks:
        for idx, _ in tb:
            table_line_set.add(idx)
    non_table_text_lines = [
        line for idx, line in enumerate(lines) if idx not in table_line_set
    ]
    non_table_text = "\n".join(non_table_text_lines)

    narrative_tokens: set[str] = set()
    narrative_tokens |= _collect_inline_code_tokens(non_table_text)
    narrative_tokens |= _collect_fenced_code_tokens(non_table_text)
    narrative_tokens |= _collect_path_qualified_tokens(non_table_text)

    # Table-only tokens = those appearing in flat-enum columns AND without any
    # narrative mention in the file body.
    return {t for t in table_tokens if t not in narrative_tokens}


def collect_wiring_signals(text: str) -> set[str]:
    """Return the set of ``cortex-*`` tokens wired by R4 in this file.

    Honors R5 exclusions and R6 flat-enumeration narrowing.
    """
    cleaned = _strip_excluded_tokens(text)
    wired: set[str] = set()
    wired |= _collect_path_qualified_tokens(cleaned)
    wired |= _collect_inline_code_tokens(cleaned)
    wired |= _collect_fenced_code_tokens(cleaned)
    wired |= _collect_shell_invocation_tokens(cleaned)
    # R6: drop table-only tokens.
    table_only = _table_only_tokens(text)
    wired -= table_only
    # R5(c) on the wiring set: defensive — an allowlist row for a plugin name
    # is impossible by R8 schema, so this is a no-op in practice. R5(d)
    # (SELF_REFERENCE) is candidate-side only — wiring of cortex-check-parity
    # via bin/cortex-check-parity in justfile must remain visible.
    wired = {t for t in wired if t not in PLUGIN_NAMES}
    return wired


# ---------------------------------------------------------------------------
# Reference candidates (R5)
# ---------------------------------------------------------------------------


def collect_reference_candidates(text: str) -> set[str]:
    """Return the set of tokens that pass R5(a)-(e) filters.

    These are candidates for E002/W003 evaluation. R5 is the inverse of R4 —
    it identifies which tokens should be checked against the deployed bin/
    set.
    """
    cleaned = _strip_excluded_tokens(text)
    candidates: set[str] = set()
    # Path-qualified tokens always candidates (after R5(a) strip).
    candidates |= _collect_path_qualified_tokens(cleaned)
    # Inline-code and fenced-code tokens (R5(b) and R5(e) applied internally).
    candidates |= _collect_inline_code_tokens(cleaned)
    candidates |= _collect_fenced_code_tokens(cleaned)
    candidates |= _collect_shell_invocation_tokens(cleaned)
    # Drop R5(c) plugin names + reserved non-bin names; drop R5(d) self-reference.
    candidates = {
        t
        for t in candidates
        if t not in PLUGIN_NAMES
        and t not in RESERVED_NON_BIN_NAMES
        and t != SELF_REFERENCE
    }
    return candidates


# ---------------------------------------------------------------------------
# Source location for first reference (used in violation messages)
# ---------------------------------------------------------------------------


def find_first_reference(text: str, token: str) -> tuple[int, int] | None:
    """Locate first line/col of ``token`` in ``text`` (1-indexed)."""
    for idx, line in enumerate(text.splitlines(), start=1):
        col = line.find(token)
        if col >= 0:
            return idx, col + 1
    return None


# ---------------------------------------------------------------------------
# --staged input (R13)
# ---------------------------------------------------------------------------


def _read_staged_blob(path: str, root: Path) -> str | None:
    """Return the staged version of ``path`` or None on missing/binary."""
    try:
        out = subprocess.run(
            ["git", "show", f":{path}"],
            cwd=str(root),
            capture_output=True,
            check=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None
    try:
        return out.stdout.decode("utf-8")
    except UnicodeDecodeError:
        return None


def _staged_paths(root: Path) -> list[str]:
    try:
        out = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMRD"],
            cwd=str(root),
            capture_output=True,
            check=True,
            text=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []
    return [ln for ln in out.stdout.splitlines() if ln]


def _matches_scan_glob(rel_path: str) -> bool:
    """True if ``rel_path`` matches any R7 glob (used by --staged)."""
    p = Path(rel_path)
    for glob in SCAN_GLOBS:
        if "*" not in glob:
            if str(p) == glob:
                return True
            continue
        if p.match(glob):
            return True
    return False


# ---------------------------------------------------------------------------
# Core lint
# ---------------------------------------------------------------------------


def _gather_staged_inscope_texts(root: Path) -> list[tuple[str, str]]:
    """Return [(path, blob_text), ...] for staged paths matching scan globs."""
    out: list[tuple[str, str]] = []
    for rel in _staged_paths(root):
        if not _matches_scan_glob(rel):
            continue
        text = _read_staged_blob(rel, root)
        if text is None:
            continue
        out.append((rel, text))
    return out


def lint(
    root: Path,
    *,
    staged: bool = False,
) -> tuple[list[Violation], list[Violation]]:
    """Run the linter against ``root``.

    Returns (errors, warnings).
    """
    errors: list[Violation] = []
    warnings: list[Violation] = []

    # 1. Allowlist.
    rows, allow_viol, _ = load_allowlist(root)
    errors.extend(allow_viol)
    allowlisted: dict[str, AllowlistRow] = {r.script: r for r in rows}

    # 2. Gather scan corpus.
    # In --staged mode, the corpus is the working-tree scan with staged blobs
    # overlaid on top: each staged in-scope file replaces its working-tree
    # contents. Unstaged files still contribute. This matches R13 intent
    # ("referenced set from staged blobs PLUS working-tree wiring") and
    # avoids spurious W003 reports when a commit stages only out-of-scope
    # files (e.g., a comment-only edit to bin/.parity-exceptions.md).
    file_corpus: list[tuple[str, str]] = []
    staged_overlay: dict[str, str] = {}
    if staged:
        for rel, text in _gather_staged_inscope_texts(root):
            staged_overlay[rel] = text
    for p in gather_scan_files(root):
        rel = str(p.relative_to(root)) if p.is_absolute() else str(p)
        if rel in staged_overlay:
            file_corpus.append((rel, staged_overlay.pop(rel)))
            continue
        try:
            text = p.read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError):
            continue
        file_corpus.append((rel, text))
    # Any staged-only paths (newly added files not yet in the working-tree
    # glob enumeration) are appended last.
    for rel, text in staged_overlay.items():
        file_corpus.append((rel, text))

    # 3. Wiring + candidate sets.
    wired: dict[str, list[tuple[str, int, int]]] = {}
    referenced: dict[str, list[tuple[str, int, int]]] = {}
    for path, text in file_corpus:
        for tok in collect_wiring_signals(text):
            loc = find_first_reference(text, tok) or (1, 1)
            wired.setdefault(tok, []).append((path, loc[0], loc[1]))
        for tok in collect_reference_candidates(text):
            loc = find_first_reference(text, tok) or (1, 1)
            referenced.setdefault(tok, []).append((path, loc[0], loc[1]))

    # 4. Deployed set (always working tree).
    deployed = gather_deployed(root)

    # 5. E002 drift: referenced (cortex-*) but not deployed and not allowlisted.
    for tok in sorted(referenced):
        if tok in deployed:
            continue
        if tok in allowlisted:
            continue
        first = referenced[tok][0]
        errors.append(
            Violation(
                first[0],
                first[1],
                first[2],
                "E002",
                f"drift: {tok!r} referenced but not deployed in bin/",
            )
        )

    # 6. W003 orphan: deployed cortex-* but no wiring signal anywhere.
    for name in sorted(deployed):
        if not name.startswith("cortex-"):
            # Un-prefixed scripts — only flagged if not allowlisted.
            if name in allowlisted:
                continue
            # Check loose token search across the corpus.
            wired_loose = any(
                _has_loose_wiring(text, name) for _, text in file_corpus
            )
            if wired_loose:
                continue
            warnings.append(
                Violation(
                    f"bin/{name}",
                    1,
                    1,
                    "W003",
                    f"orphan: {name!r} deployed but not referenced in scope",
                )
            )
            continue
        if name in wired:
            continue
        if name in allowlisted:
            continue
        warnings.append(
            Violation(
                f"bin/{name}",
                1,
                1,
                "W003",
                f"orphan: {name!r} deployed but not referenced in scope",
            )
        )

    # 7. W005 allowlist-superfluous: allowlisted AND has wiring signal in scope.
    for tok, row in allowlisted.items():
        if tok in wired:
            warnings.append(
                Violation(
                    ALLOWLIST_PATH,
                    row.line,
                    1,
                    "W005",
                    f"allowlist-superfluous: {tok!r} is allowlisted but has a wiring signal in scope",
                )
            )

    return errors, warnings


def _has_loose_wiring(text: str, name: str) -> bool:
    """Loose wiring check for un-prefixed allowlisted scripts.

    Recognizes path-qualified ``bin/NAME`` references in any context.
    """
    pattern = re.compile(r"bin/" + re.escape(name) + r"(?![A-Za-z0-9_\-])")
    return bool(pattern.search(text))


# ---------------------------------------------------------------------------
# Bare python3 -m cortex_command.* audit gate (R12 part c/d/e)
# ---------------------------------------------------------------------------


def _parse_bare_python_m_allowlist(
    text: str,
    *,
    source_path: str = BARE_PYTHON_M_ALLOWLIST_PATH,
) -> tuple[set[tuple[str, int]], list[str]]:
    """Parse bin/.audit-bare-python-m-allowlist.md and return allowlisted (file, line) pairs.

    The allowlist format uses ``## Entries`` section with ``### <file>:<line>[, :<line>...]``
    headings and field tables. Each heading may list multiple line numbers (comma-separated
    with optional ``:`` prefix on subsequent numbers).

    Returns (allowed_pairs, errors) where ``allowed_pairs`` is a set of (rel_path, line_number)
    tuples and ``errors`` is a list of human-readable parse-error strings.
    """
    allowed: set[tuple[str, int]] = set()
    errors: list[str] = []

    in_entries_section = False
    current_file: str | None = None
    current_lines: list[int] = []
    current_category: str | None = None
    current_rationale: str | None = None

    def _commit_entry(heading_text: str) -> None:
        """Validate and commit the current entry to allowed set."""
        if current_file is None:
            return
        if not current_lines:
            errors.append(f"{source_path}: entry '{heading_text}' has no parseable line numbers")
            return
        if current_category not in BARE_PYTHON_M_ALLOWED_CATEGORIES:
            errors.append(
                f"{source_path}: entry '{heading_text}' has invalid category "
                f"{current_category!r} — must be one of "
                f"{sorted(BARE_PYTHON_M_ALLOWED_CATEGORIES)}"
            )
            return
        rationale = (current_rationale or "").strip()
        if len(rationale) < 30:
            errors.append(
                f"{source_path}: entry '{heading_text}' rationale too short "
                f"({len(rationale)} chars, need ≥30)"
            )
            return
        for ln in current_lines:
            allowed.add((current_file, ln))

    # We iterate twice: first to extract entries with a simple state machine.
    last_heading: str = ""
    state_file: str | None = None
    state_lines: list[int] = []
    state_category: str | None = None
    state_rationale: str | None = None

    for raw_line in text.splitlines():
        line = raw_line.strip()

        # Detect ## Entries section header.
        if line == "## Entries":
            in_entries_section = True
            continue

        if not in_entries_section:
            continue

        # Detect a new entry heading: ### <file>:<line>[, :<line>...]
        if line.startswith("### "):
            # Commit previous entry if any.
            if state_file is not None:
                # validate + commit
                if not state_lines:
                    errors.append(
                        f"{source_path}: entry '{last_heading}' has no parseable line numbers"
                    )
                elif state_category not in BARE_PYTHON_M_ALLOWED_CATEGORIES:
                    errors.append(
                        f"{source_path}: entry '{last_heading}' has invalid category "
                        f"{state_category!r} — must be one of "
                        f"{sorted(BARE_PYTHON_M_ALLOWED_CATEGORIES)}"
                    )
                else:
                    rationale = (state_rationale or "").strip()
                    if len(rationale) < 30:
                        errors.append(
                            f"{source_path}: entry '{last_heading}' rationale too short "
                            f"({len(rationale)} chars, need ≥30)"
                        )
                    else:
                        for ln in state_lines:
                            allowed.add((state_file, ln))

            heading_body = line[4:].strip()  # strip "### "
            last_heading = heading_body
            state_file = None
            state_lines = []
            state_category = None
            state_rationale = None

            # Parse the heading: "filename:N[, :M, :P]"
            # Split on first colon to get filename; then parse line numbers.
            colon_idx = heading_body.find(":")
            if colon_idx < 0:
                errors.append(
                    f"{source_path}: heading '{heading_body}' has no ':' separator for line number"
                )
                continue
            state_file = heading_body[:colon_idx].strip()
            line_part = heading_body[colon_idx + 1:]
            # line_part may be "507" or "319, :332" or "356, :403, :419"
            for token in line_part.split(","):
                token = token.strip().lstrip(":")
                try:
                    state_lines.append(int(token))
                except ValueError:
                    errors.append(
                        f"{source_path}: cannot parse line number {token!r} in heading '{heading_body}'"
                    )
            continue

        # Detect field table rows: | field | value |
        if line.startswith("|") and state_file is not None:
            cells = [c.strip() for c in line.strip("|").split("|")]
            if len(cells) == 2:
                field, value = cells[0].strip().lower(), cells[1].strip()
                # Strip backticks from value.
                value = value.strip("`").strip()
                if field == "category":
                    state_category = value
                elif field == "rationale":
                    state_rationale = value
            continue

    # Commit last entry.
    if state_file is not None:
        if not state_lines:
            errors.append(
                f"{source_path}: entry '{last_heading}' has no parseable line numbers"
            )
        elif state_category not in BARE_PYTHON_M_ALLOWED_CATEGORIES:
            errors.append(
                f"{source_path}: entry '{last_heading}' has invalid category "
                f"{state_category!r} — must be one of "
                f"{sorted(BARE_PYTHON_M_ALLOWED_CATEGORIES)}"
            )
        else:
            rationale = (state_rationale or "").strip()
            if len(rationale) < 30:
                errors.append(
                    f"{source_path}: entry '{last_heading}' rationale too short "
                    f"({len(rationale)} chars, need ≥30)"
                )
            else:
                for ln in state_lines:
                    allowed.add((state_file, ln))

    return allowed, errors


def _grep_bare_python_m_callsites(root: Path) -> list[tuple[str, int, str]]:
    """Grep for ``python3 -m cortex_command.`` across BARE_PYTHON_M_SCAN_PATHS.

    Returns a list of (rel_path, line_number, matched_line) triples.
    Skips the allowlist file and this tool itself to avoid false positives.
    """
    pattern = "python3 -m cortex_command."
    # Files excluded from the scan: the allowlist (contains rationale text) and
    # this tool's own source (contains the pattern as string literals and comments).
    excluded_rel_paths: frozenset[str] = frozenset(
        {
            BARE_PYTHON_M_ALLOWLIST_PATH,
            f"bin/{SELF_REFERENCE}",
        }
    )
    results: list[tuple[str, int, str]] = []

    for path_fragment in BARE_PYTHON_M_SCAN_PATHS:
        target = root / path_fragment
        if target.is_file():
            # Single file (e.g. justfile).
            rel = path_fragment
            if rel in excluded_rel_paths:
                continue
            try:
                text = target.read_text(encoding="utf-8", errors="replace")
            except OSError:
                continue
            for idx, line_text in enumerate(text.splitlines(), start=1):
                if pattern in line_text:
                    results.append((rel, idx, line_text))
        elif target.is_dir():
            # Walk recursively.
            for dirpath, _dirnames, filenames in os.walk(target):
                for fname in filenames:
                    abs_file = Path(dirpath) / fname
                    try:
                        rel = str(abs_file.relative_to(root))
                    except ValueError:
                        continue
                    if rel in excluded_rel_paths:
                        continue
                    try:
                        text = abs_file.read_text(encoding="utf-8", errors="replace")
                    except OSError:
                        continue
                    for idx, line_text in enumerate(text.splitlines(), start=1):
                        if pattern in line_text:
                            results.append((rel, idx, line_text))

    return results


def audit_bare_python_m_callsites(root: Path) -> tuple[list[str], list[str]]:
    """Run the bare-python-m callsite audit (R12 part c).

    Returns (violations, parse_errors). Violations are human-readable strings;
    parse_errors are allowlist schema errors (treated as fatal by the caller).
    Exit 0 iff both lists are empty.
    """
    allowlist_path = root / BARE_PYTHON_M_ALLOWLIST_PATH
    if not allowlist_path.is_file():
        return (
            [],
            [f"{BARE_PYTHON_M_ALLOWLIST_PATH}: allowlist file not found — cannot audit"],
        )

    try:
        allowlist_text = allowlist_path.read_text(encoding="utf-8")
    except OSError as exc:
        return [], [f"{BARE_PYTHON_M_ALLOWLIST_PATH}: cannot read: {exc}"]

    allowed_pairs, parse_errors = _parse_bare_python_m_allowlist(allowlist_text)
    if parse_errors:
        return [], parse_errors

    hits = _grep_bare_python_m_callsites(root)
    violations: list[str] = []
    for rel, lineno, line_text in sorted(hits):
        if (rel, lineno) in allowed_pairs:
            continue
        violations.append(
            f"{rel}:{lineno}: bare 'python3 -m cortex_command.*' callsite not in allowlist"
            f" — add to {BARE_PYTHON_M_ALLOWLIST_PATH} with rationale or replace with"
            f" the promoted console-script name"
        )
    return violations, []


# ---------------------------------------------------------------------------
# Sandbox pre-flight gate (spec Req 17 / Task 12)
# ---------------------------------------------------------------------------


def _staged_diff_hunks(path: str, root: Path) -> str:
    """Return ``git diff --cached -U0 -- <path>`` output (added-line content).

    Returns empty string if the file is not staged or git fails. Only the
    ``+``-prefixed added lines are extracted (excluding the ``+++`` header
    line) so renames/whitespace shifts don't generate false positives.
    """
    try:
        out = subprocess.run(
            ["git", "diff", "--cached", "-U0", "--", path],
            cwd=str(root),
            capture_output=True,
            check=False,
            text=True,
        )
    except (FileNotFoundError, OSError):
        return ""
    if out.returncode != 0:
        return ""
    added: list[str] = []
    for ln in out.stdout.splitlines():
        # Skip diff metadata; capture only added-line content.
        if ln.startswith("+++"):
            continue
        if ln.startswith("+"):
            added.append(ln[1:])
    return "\n".join(added)


def _gate_fires_for_file(path: str, hunk_text: str, patterns: tuple[str, ...]) -> bool:
    """True if any pattern matches the staged-hunk text for ``path``."""
    if not hunk_text:
        return False
    for pat in patterns:
        if re.search(pat, hunk_text):
            return True
    return False


def _detect_sandbox_source_changes(root: Path) -> list[str]:
    """Return the list of watched-file paths whose staged hunks fire the gate."""
    fired: list[str] = []
    for path, patterns in SANDBOX_WATCHED_FILES.items():
        hunk = _staged_diff_hunks(path, root)
        if _gate_fires_for_file(path, hunk, patterns):
            fired.append(path)
    return fired


def _resolve_preflight_target_hash(root: Path) -> str | None:
    """Return the commit hash that ``preflight.md::commit_hash`` must match.

    The gate runs **pre-commit**, so the staged change has not yet become a
    commit. ``commit_hash`` in preflight.md is documented to be "the full sha
    of the cortex-command HEAD at preflight-run time" — i.e., the most-recent
    existing commit at the moment the human ran the preflight test.

    At gate time (pre-commit), the most-recent existing commit IS current
    ``HEAD`` (the staged change is the about-to-be-created NEW commit, not
    yet HEAD). So we resolve ``git rev-parse HEAD``. The hash binding is
    self-invalidating: once any sandbox-source commit lands, current HEAD
    advances and the recorded hash no longer matches → a new preflight is
    required. (The spec text mentions ``HEAD~`` in passing, but the
    workflow it describes — "preflight then stage sandbox-source change" —
    only self-consistent if the comparison target is current HEAD at
    pre-commit gate time, not HEAD~.)
    """
    try:
        out = subprocess.run(
            ["git", "rev-parse", "HEAD"],
            cwd=str(root),
            capture_output=True,
            check=False,
            text=True,
        )
    except (FileNotFoundError, OSError):
        return None
    if out.returncode != 0:
        return None
    return out.stdout.strip() or None


def _capture_claude_version() -> str | None:
    """Return ``claude --version`` stdout (stripped) or None if unavailable."""
    try:
        out = subprocess.run(
            ["claude", "--version"],
            capture_output=True,
            check=False,
            text=True,
            timeout=10,
        )
    except (FileNotFoundError, OSError, subprocess.TimeoutExpired):
        return None
    if out.returncode != 0:
        return None
    return out.stdout.strip() or None


def _parse_preflight_yaml(text: str) -> tuple[dict | None, str | None]:
    """Extract and parse the embedded YAML block from preflight.md.

    The file may contain a fenced ```yaml ... ``` block; this helper extracts
    the first such block and returns ``(parsed_dict, error)``. On error,
    returns ``(None, error_message)``.
    """
    m = re.search(r"```yaml\s*\n(.*?)\n```", text, re.DOTALL)
    if not m:
        return None, "no fenced ```yaml block found in preflight.md"
    yaml_body = m.group(1)
    try:
        import yaml  # type: ignore
    except ImportError:
        return None, "PyYAML not installed (required for preflight gate)"
    try:
        data = yaml.safe_load(yaml_body)
    except Exception as exc:  # YAML parser raises various exception types
        return None, f"YAML parse error: {exc}"
    if not isinstance(data, dict):
        return None, "preflight YAML block did not parse as a mapping"
    return data, None


def _validate_preflight_schema(data: dict) -> list[str]:
    """Return a list of schema-violation messages; empty list = valid."""
    errors: list[str] = []
    required_fields = {
        "pass": bool,
        "timestamp": str,
        "commit_hash": str,
        "claude_version": str,
        "test_command": str,
        "exit_code": int,
        "stderr_contains_eperm": bool,
        "stderr_excerpt": str,
        "target_path": str,
        "target_unmodified": bool,
    }
    for field, expected_type in required_fields.items():
        if field not in data:
            errors.append(f"missing required field {field!r}")
            continue
        value = data[field]
        # bool is a subclass of int in Python; tighten the check.
        if expected_type is bool and not isinstance(value, bool):
            errors.append(f"field {field!r} must be bool, got {type(value).__name__}")
            continue
        if expected_type is int and isinstance(value, bool):
            errors.append(f"field {field!r} must be int (not bool)")
            continue
        if not isinstance(value, expected_type):
            errors.append(
                f"field {field!r} must be {expected_type.__name__}, "
                f"got {type(value).__name__}"
            )
    if errors:
        return errors
    # Semantic checks: gate only passes when the recorded run actually denied.
    # exit_code is recorded for forensics but NOT asserted: claude -p wraps inner
    # tool failures gracefully and exits 0 even when a Bash subprocess hit EPERM.
    # Kernel-enforcement signals (target_unmodified + stderr_contains_eperm) are
    # the load-bearing checks; the wrapper's exit code is incidental.
    if data.get("pass") is not True:
        errors.append("field 'pass' must be true (preflight did not record a passing run)")
    if data.get("stderr_contains_eperm") is not True:
        errors.append("field 'stderr_contains_eperm' must be true")
    if data.get("target_unmodified") is not True:
        errors.append("field 'target_unmodified' must be true")
    return errors


def _check_sandbox_preflight_gate(root: Path) -> list[Violation]:
    """Run the structured preflight gate per spec Req 17.

    Returns a list of Violations (E100-series). Empty list means the gate did
    not fire OR fired and passed all checks.
    """
    violations: list[Violation] = []

    fired_files = _detect_sandbox_source_changes(root)
    if not fired_files:
        return []  # gate did not fire — no sandbox-source changes staged

    # Gate fired: validate preflight.md exists.
    preflight_abs = root / PREFLIGHT_PATH
    if not preflight_abs.is_file():
        violations.append(
            Violation(
                PREFLIGHT_PATH,
                1,
                1,
                "E100",
                f"sandbox preflight gate fired ({', '.join(fired_files)}) "
                f"but {PREFLIGHT_PATH} is missing — re-run pre-flight per spec Req 12",
            )
        )
        return violations

    try:
        text = preflight_abs.read_text(encoding="utf-8")
    except OSError as exc:
        violations.append(
            Violation(PREFLIGHT_PATH, 1, 1, "E100", f"cannot read preflight: {exc}")
        )
        return violations

    data, parse_err = _parse_preflight_yaml(text)
    if data is None:
        violations.append(
            Violation(
                PREFLIGHT_PATH,
                1,
                1,
                "E101",
                f"preflight schema invalid: {parse_err}",
            )
        )
        return violations

    schema_errors = _validate_preflight_schema(data)
    if schema_errors:
        for err in schema_errors:
            violations.append(
                Violation(PREFLIGHT_PATH, 1, 1, "E101", f"preflight schema invalid: {err}")
            )
        return violations

    # Commit-hash freshness check: recorded hash must match current HEAD
    # at gate time (gate runs pre-commit; staged change is not yet a commit;
    # current HEAD is the most-recent existing commit, which is the value
    # the human recorded when running the preflight test).
    head = _resolve_preflight_target_hash(root)
    if head is None:
        violations.append(
            Violation(
                PREFLIGHT_PATH,
                1,
                1,
                "E102",
                "cannot resolve git HEAD for commit-hash freshness check",
            )
        )
        return violations
    recorded_hash = str(data.get("commit_hash", "")).strip()
    if recorded_hash != head:
        violations.append(
            Violation(
                PREFLIGHT_PATH,
                1,
                1,
                "E102",
                f"preflight evidence is stale relative to current sandbox-source "
                f"state — re-run pre-flight against HEAD "
                f"(recorded={recorded_hash[:12] or '<empty>'}, HEAD={head[:12]})",
            )
        )

    # claude --version drift check
    current_version = _capture_claude_version()
    recorded_version = str(data.get("claude_version", "")).strip()
    if current_version is None:
        violations.append(
            Violation(
                PREFLIGHT_PATH,
                1,
                1,
                "E103",
                "cannot invoke `claude --version` for drift check",
            )
        )
    elif current_version != recorded_version:
        violations.append(
            Violation(
                PREFLIGHT_PATH,
                1,
                1,
                "E103",
                f"claude binary drift between preflight and current install — "
                f"re-run preflight (recorded={recorded_version!r}, "
                f"current={current_version!r})",
            )
        )

    return violations


# ---------------------------------------------------------------------------
# Self-test (R18)
# ---------------------------------------------------------------------------


SELF_TEST_CASES = [
    "valid-path-qualified",
    "valid-code-span",
    "valid-fenced-code",
    "valid-allowlist",
    "exclude-hook-suffix",
    "exclude-plugin-name",
    "exclude-hook-path",
    "exclude-self-reference",
    "exclude-leading-dot",
    "exclude-reserved-non-bin-name",
    "invalid-allowlist-row",
    "invalid-drift",
    "invalid-orphan",
    "invalid-entry-point-orphan",
    "invalid-allowlist-superfluous",
    "plugin-list-matches-justfile",
]


def _run_self_test_case(name: str) -> tuple[bool, str]:
    """Return (pass, detail). detail is a short error message on failure."""
    if name == "valid-path-qualified":
        text = "See `bin/cortex-foo` for details."
        wired = collect_wiring_signals(text)
        if "cortex-foo" not in wired:
            return False, "expected cortex-foo wired by path-qualified mention"
        return True, ""
    if name == "valid-code-span":
        text = "Run `cortex-foo` to invoke."
        wired = collect_wiring_signals(text)
        if "cortex-foo" not in wired:
            return False, "expected cortex-foo wired by inline code span"
        return True, ""
    if name == "valid-fenced-code":
        text = "```bash\ncortex-foo --help\n```\n"
        wired = collect_wiring_signals(text)
        if "cortex-foo" not in wired:
            return False, "expected cortex-foo wired by fenced code block"
        return True, ""
    if name == "valid-allowlist":
        rows, viol = parse_allowlist(
            "| script | category | rationale | lifecycle_id | added_date |\n"
            "| --- | --- | --- | --- | --- |\n"
            "| `cortex-foo` | `maintainer-only-tool` | "
            "A long enough rationale describing why this script needs allowlisting. "
            "| `123` | `2026-04-27` |\n"
        )
        if viol:
            return False, f"unexpected E001s: {[v.code for v in viol]}"
        if len(rows) != 1 or rows[0].script != "cortex-foo":
            return False, f"expected 1 row, got {[r.script for r in rows]}"
        return True, ""
    if name == "exclude-hook-suffix":
        text = "Hook script `cortex-validate-commit.sh` runs first."
        cands = collect_reference_candidates(text)
        if "cortex-validate-commit" in cands:
            return False, "R5(b) failed: .sh suffix did not exclude token"
        return True, ""
    if name == "exclude-plugin-name":
        text = "The `cortex-pr-review` plugin is hand-maintained."
        cands = collect_reference_candidates(text)
        if "cortex-pr-review" in cands:
            return False, "R5(c) failed: plugin name not excluded"
        return True, ""
    if name == "exclude-hook-path":
        text = "See hooks/cortex-pre-commit-handler for the wiring."
        cands = collect_reference_candidates(text)
        if "cortex-pre-commit-handler" in cands:
            return False, "R5(a) failed: hooks/-prefixed token not excluded"
        return True, ""
    if name == "exclude-self-reference":
        text = "Inside the linter we mention cortex-check-parity."
        cands = collect_reference_candidates("`cortex-check-parity`")
        if "cortex-check-parity" in cands:
            return False, "R5(d) failed: self-reference not excluded"
        # Wiring side intentionally retains the self-reference so a
        # ``bin/cortex-check-parity`` mention in justfile counts as wiring.
        wired = collect_wiring_signals("`bin/cortex-check-parity`")
        if "cortex-check-parity" not in wired:
            return False, "R5(d) misapplied to wiring set: self-reference dropped from wired"
        return True, ""
    if name == "exclude-leading-dot":
        # R5(e): tokens preceded immediately by ``.`` are file/marker names.
        text_inline = "The `.cortex-init` marker file is checked."
        cands = collect_reference_candidates(text_inline)
        if "cortex-init" in cands:
            return False, "R5(e) failed (inline): .cortex-init produced cortex-init candidate"
        text_fenced = "```\nfoo .cortex-update.lock bar\n```\n"
        cands_f = collect_reference_candidates(text_fenced)
        if "cortex-update" in cands_f:
            return False, "R5(e) failed (fenced): .cortex-update produced cortex-update candidate"
        return True, ""
    if name == "exclude-reserved-non-bin-name":
        # R5(c) extension: reserved cortex-prefixed identifiers not deployed as bin scripts.
        for tok in ("cortex-command", "cortex-overnight"):
            cands = collect_reference_candidates(f"See `{tok}` in docs.")
            if tok in cands:
                return False, f"R5(c) reserved-name failed: {tok} not excluded"
        return True, ""
    if name == "invalid-allowlist-row":
        cases = [
            (
                "empty rationale",
                "| script | category | rationale | lifecycle_id | added_date |\n"
                "| --- | --- | --- | --- | --- |\n"
                "| `cortex-foo` | `maintainer-only-tool` |  | `1` | `2026-04-27` |\n",
            ),
            (
                "bad category",
                "| script | category | rationale | lifecycle_id | added_date |\n"
                "| --- | --- | --- | --- | --- |\n"
                "| `cortex-foo` | `experimental` | "
                "this rationale is more than thirty chars long indeed "
                "| `1` | `2026-04-27` |\n",
            ),
            (
                "forbidden literal rationale",
                "| script | category | rationale | lifecycle_id | added_date |\n"
                "| --- | --- | --- | --- | --- |\n"
                "| `cortex-foo` | `maintainer-only-tool` | internal | `1` | `2026-04-27` |\n",
            ),
            (
                "rationale too short",
                "| script | category | rationale | lifecycle_id | added_date |\n"
                "| --- | --- | --- | --- | --- |\n"
                "| `cortex-foo` | `maintainer-only-tool` | short reason | `1` | `2026-04-27` |\n",
            ),
            (
                "missing date",
                "| script | category | rationale | lifecycle_id | added_date |\n"
                "| --- | --- | --- | --- | --- |\n"
                "| `cortex-foo` | `maintainer-only-tool` | "
                "a sufficiently long rationale describing the reason "
                "| `1` |  |\n",
            ),
            (
                "malformed date",
                "| script | category | rationale | lifecycle_id | added_date |\n"
                "| --- | --- | --- | --- | --- |\n"
                "| `cortex-foo` | `maintainer-only-tool` | "
                "a sufficiently long rationale describing the reason "
                "| `1` | `2026/01/01` |\n",
            ),
        ]
        for label, blob in cases:
            rows, viol = parse_allowlist(blob)
            if not viol:
                return False, f"{label}: expected E001, got none"
            if any(v.code != "E001" for v in viol):
                return False, f"{label}: non-E001 in {[v.code for v in viol]}"
        return True, ""
    if name == "invalid-drift":
        # Synthetic: referenced cortex-foo but bin/ has no such script.
        text = "Run `bin/cortex-foo` to start."
        cands = collect_reference_candidates(text)
        if "cortex-foo" not in cands:
            return False, "expected cortex-foo as a candidate"
        # Drift is a top-level lint result; here we just verify candidate set.
        return True, ""
    if name == "invalid-orphan":
        # Synthetic: deployed cortex-foo but no wiring signal.
        text = "This file does not mention any token."
        wired = collect_wiring_signals(text)
        if wired:
            return False, f"unexpected wiring tokens: {wired}"
        return True, ""
    if name == "invalid-entry-point-orphan":
        # Synthetic: pyproject.toml declares cortex-orphan-test as a
        # [project.scripts] entry point, but nothing in scope wires it.
        # gather_deployed must surface it (so W003 has something to fire on)
        # AND the lint pass must produce a W003 for it.
        import tempfile

        with tempfile.TemporaryDirectory() as tmpdir:
            root = Path(tmpdir)
            (root / "bin").mkdir()
            (root / "pyproject.toml").write_text(
                "[project]\n"
                'name = "fixture"\n'
                "version = \"0.0.0\"\n\n"
                "[project.scripts]\n"
                'cortex-orphan-test = "cortex_command.test:main"\n',
                encoding="utf-8",
            )
            deployed = gather_deployed(root)
            if "cortex-orphan-test" not in deployed:
                return False, (
                    "expected cortex-orphan-test in deployed via "
                    "[project.scripts]"
                )
            _errors, warnings = lint(root)
            w003 = [
                v
                for v in warnings
                if v.code == "W003" and "cortex-orphan-test" in v.message
            ]
            if not w003:
                return False, "expected W003 to fire on unwired entry point"
        return True, ""
    if name == "invalid-allowlist-superfluous":
        # cortex-foo wired AND allowlisted → emit W005 in lint().
        text = "Run `bin/cortex-foo` for stuff."
        wired = collect_wiring_signals(text)
        if "cortex-foo" not in wired:
            return False, "expected cortex-foo wired"
        return True, ""
    if name == "plugin-list-matches-justfile":
        jf = Path("justfile")
        if not jf.is_file():
            return True, ""  # graceful no-op outside repo
        try:
            jt = jf.read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError) as exc:
            return False, f"cannot read justfile: {exc}"
        names: set[str] = set()
        for var in ("BUILD_OUTPUT_PLUGINS", "HAND_MAINTAINED_PLUGINS"):
            # Try just-style assignment first: ``VAR := "name1 name2"``.
            m = re.search(
                rf'^{var}\s*:?=\s*"([^"]*)"', jt, flags=re.MULTILINE
            )
            if m:
                names |= {tok for tok in m.group(1).split() if tok}
                continue
            # Try Bash-array form: ``VAR=(name1 name2)``.
            m = re.search(rf"^{var}=\(([^)]*)\)", jt, flags=re.MULTILINE)
            if m:
                names |= {tok for tok in m.group(1).split() if tok}
                continue
            return False, f"could not locate {var} in justfile"
        if names != set(PLUGIN_NAMES):
            extra = names - set(PLUGIN_NAMES)
            missing = set(PLUGIN_NAMES) - names
            return (
                False,
                f"plugin list drift: justfile-only={sorted(extra)} "
                f"linter-only={sorted(missing)}",
            )
        return True, ""
    return False, f"unknown self-test case {name}"


def run_self_test(verbose: bool, as_json: bool = False) -> int:
    failed: list[tuple[str, str]] = []
    results: list[dict[str, object]] = []
    for case in SELF_TEST_CASES:
        ok, detail = _run_self_test_case(case)
        results.append({"case": case, "pass": ok, "detail": detail})
        if ok:
            if verbose and not as_json:
                print(f"PASS {case}")
        else:
            if not as_json:
                print(f"FAIL {case}: {detail}", file=sys.stderr)
            failed.append((case, detail))
    if as_json:
        print(json.dumps(results))
    if failed:
        if not as_json:
            print(f"self-test failed: {len(failed)} case(s)", file=sys.stderr)
        return 1
    if not as_json:
        print("self-test passed")
    return 0


# ---------------------------------------------------------------------------
# Reporting
# ---------------------------------------------------------------------------


def emit(
    errors: Iterable[Violation],
    warnings: Iterable[Violation],
    *,
    as_json: bool,
) -> None:
    if as_json:
        payload = [v.to_dict() for v in list(errors) + list(warnings)]
        print(json.dumps(payload))
        return
    for v in errors:
        print(v.format_text())
    for v in warnings:
        print(v.format_text())


def determine_exit(
    errors: list[Violation], warnings: list[Violation], lenient: bool
) -> int:
    if errors:
        return 1
    if warnings and not lenient:
        return 1
    return 0


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="cortex-check-parity",
        description="SKILL.md-to-bin parity linter",
    )
    p.add_argument("--self-test", action="store_true", help="Run inline self-test fixtures and exit")
    p.add_argument("--json", dest="as_json", action="store_true", help="Emit JSON array of violations")
    p.add_argument("--lenient", action="store_true", help="Downgrade W003/W005 to non-failing warnings")
    p.add_argument("--staged", action="store_true", help="Read referenced set from git staged blobs (R13)")
    p.add_argument("--print-scan-paths", action="store_true", help="Print the R7 scan globs (sorted) and exit")
    p.add_argument("--verbose", action="store_true", help="Verbose self-test output (PASS lines)")
    p.add_argument(
        "--audit-bare-python-m-callsites",
        action="store_true",
        help=(
            "Audit repo for bare 'python3 -m cortex_command.*' callsites (R12 part c). "
            "Off the pre-commit critical path; invoked via morning-review or just check-bare-python-callsites."
        ),
    )
    return p


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)

    if args.print_scan_paths:
        for g in sorted(SCAN_GLOBS):
            print(g)
        return 0

    if args.self_test:
        return run_self_test(args.verbose, as_json=args.as_json)

    if args.audit_bare_python_m_callsites:
        root = Path(os.getcwd()).resolve()
        violations, parse_errors = audit_bare_python_m_callsites(root)
        if parse_errors:
            for err in parse_errors:
                print(f"ERROR: {err}", file=sys.stderr)
            return 2
        if violations:
            for v in violations:
                print(v)
            return 1
        return 0

    root = Path(os.getcwd()).resolve()
    try:
        errors, warnings = lint(root, staged=args.staged)
    except RuntimeError as exc:
        print(f"{ALLOWLIST_PATH}: E000 unparseable allowlist: {exc}", file=sys.stderr)
        return 2

    # Sandbox pre-flight gate (spec Req 17): runs unconditionally — silently
    # passes when no sandbox-source files are staged; emits E100-E103 errors
    # when staged hunks touch watched files without a fresh schema-valid
    # preflight.md whose commit_hash matches HEAD and claude_version matches
    # the current install.
    try:
        gate_violations = _check_sandbox_preflight_gate(root)
    except Exception as exc:  # defensive: gate must never crash the linter
        print(
            f"sandbox-preflight-gate: internal error ({exc}); skipping gate",
            file=sys.stderr,
        )
        gate_violations = []
    errors.extend(gate_violations)

    emit(errors, warnings, as_json=args.as_json)
    return determine_exit(errors, warnings, args.lenient)


if __name__ == "__main__":
    sys.exit(main())
