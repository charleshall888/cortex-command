#!/usr/bin/env python3
"""Audit per-feature ``events.log`` files for tier-reader divergence.

Compares two rules for extracting the active complexity tier from a lifecycle's
``events.log``:

- **last-wins** (legacy): the most-recent JSONL record carrying any ``tier``
  field, regardless of event kind. This was ``common.py:read_tier``'s rule
  prior to Task 2 of the
  ``promote-lifecycle-state-out-of-eventslog-full-reads`` feature.
- **canonical**: the tier set by the last ``lifecycle_start`` event, then
  superseded by the ``to`` field of the last ``complexity_override`` event.
  This is the rule used by ``cortex_command.overnight.report._read_tier`` and
  (post-Task 2) by ``cortex_command.common.read_tier``; it is the rule that
  ``outcome_router.requires_review`` consumes.

Any divergence between these two reads means a stray non-override ``tier``
field appears in the events log after a ``complexity_override`` — a regression
risk that would silently shift routing if the canonical reader were rolled
back. The audit is wired into the pre-commit hook (spec R2c) whenever staged
diffs touch ``cortex_command/common.py`` or ``cortex_command/overnight/report.py``.

Active-only scope (default): lifecycles whose events.log contains a
``feature_complete`` event are skipped. Closed lifecycles never re-enter the
overnight runner's decision path (`outcome_router.py:830` does not re-route
closed features), so their divergence is archeological. Pass ``--include-closed``
to audit them too.

Exit codes:
  0  clean — no divergence in scope
  1  divergence found — at least one lifecycle's two reads disagree
  2  script error
"""

from __future__ import annotations

import os, subprocess, sys; subprocess.run([os.path.join(os.path.dirname(os.path.realpath(__file__)), "cortex-log-invocation"), sys.argv[0], *sys.argv[1:]], check=False)

import argparse
import json
from pathlib import Path


def read_tier_last_wins(events_path: Path) -> str:
    """Legacy rule: most-recent record carrying any ``tier`` field wins.

    Returns ``"simple"`` if the file is absent, empty, or contains no
    ``tier`` field on any parseable record.
    """
    if not events_path.is_file():
        return "simple"
    last = "simple"
    try:
        text = events_path.read_text(encoding="utf-8")
    except OSError:
        return "simple"
    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            record = json.loads(line)
        except json.JSONDecodeError:
            continue
        if "tier" in record:
            value = record["tier"]
            if isinstance(value, str) and value:
                last = value
    return last


def read_tier_canonical(events_path: Path) -> str:
    """Canonical rule: ``lifecycle_start.tier`` superseded by
    ``complexity_override.to``. Defaults to ``"simple"``.

    Inlined (rather than importing ``cortex_command.common.read_tier``) so the
    audit does not depend on the canonical reader's import surface — the
    audit's purpose is to detect divergence FROM the canonical rule, and
    inlining keeps the comparison body self-contained.
    """
    if not events_path.is_file():
        return "simple"
    tier = "simple"
    found = False
    try:
        text = events_path.read_text(encoding="utf-8")
    except OSError:
        return "simple"
    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            record = json.loads(line)
        except json.JSONDecodeError:
            continue
        kind = record.get("event")
        if kind == "lifecycle_start":
            value = record.get("tier")
            if isinstance(value, str) and value:
                tier = value
                found = True
        elif kind == "complexity_override":
            value = record.get("to")
            if isinstance(value, str) and value:
                tier = value
                found = True
    return tier if found else "simple"


def is_closed(events_path: Path) -> bool:
    """Return True if events.log contains a ``feature_complete`` event.

    Tolerates both unspaced (``"event":"feature_complete"``) and spaced
    (``"event": "feature_complete"``) JSON serializations — both appear in
    the in-tree corpus.
    """
    try:
        text = events_path.read_text(encoding="utf-8")
    except OSError:
        return False
    return (
        '"event":"feature_complete"' in text
        or '"event": "feature_complete"' in text
    )


def audit(root: Path, include_closed: bool) -> int:
    """Scan ``<root>/lifecycle/*/events.log`` and report divergences.

    Returns 0 if no divergence in scope, 1 if any divergence found.
    """
    lifecycle_dir = root / "lifecycle"
    if not lifecycle_dir.is_dir():
        return 0
    divergent = 0
    for events_path in sorted(lifecycle_dir.glob("*/events.log")):
        if not events_path.is_file():
            continue
        if not include_closed and is_closed(events_path):
            continue
        last_wins = read_tier_last_wins(events_path)
        canonical = read_tier_canonical(events_path)
        if last_wins != canonical:
            feature = events_path.parent.name
            print(
                f"tier-divergence: {feature} last_wins={last_wins} canonical={canonical}",
                file=sys.stderr,
            )
            divergent += 1
    return 1 if divergent else 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="cortex-audit-tier-divergence",
        description=(
            "Audit lifecycle events.log files for last-wins vs canonical "
            "tier-reader divergence."
        ),
    )
    p.add_argument(
        "--root",
        default=".",
        help="Repository root to scan (default: current directory).",
    )
    p.add_argument(
        "--include-closed",
        action="store_true",
        help=(
            "Include closed lifecycles (those with a feature_complete event) "
            "in the audit. Default: skip closed lifecycles."
        ),
    )
    return p


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    root = Path(args.root).resolve()
    try:
        return audit(root, args.include_closed)
    except Exception as exc:  # defensive: never crash the pre-commit
        print(f"cortex-audit-tier-divergence: internal error: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    sys.exit(main())
