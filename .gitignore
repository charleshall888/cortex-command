# Worktree directories
.claude/worktrees/
worktrees/

# Lifecycle ephemeral session files
cortex/lifecycle/*/.session
cortex/lifecycle/*/.session-owner
cortex/lifecycle/*/.dispatching

# Runtime logs
claude/statusline.sh.log
claude/statusline.log

# Python
.venv/
*.pyc
__pycache__/

# Dashboard dev artifacts
claude/dashboard/node_modules/
claude/dashboard/package-lock.json

# Lifecycle runtime artifacts
cortex/lifecycle/*/agent-activity.jsonl
cortex/lifecycle/overnight-events-*.log
cortex/lifecycle/*/learnings/recovery-log.md

# Abandoned tempfiles from interrupted atomic writes in daytime pipeline
cortex/lifecycle/*/.daytime-result-*.tmp
cortex/lifecycle/*/.daytime-dispatch-*.tmp

# Backlog audit logs
cortex/backlog/*.events.jsonl

# Overnight session archives
cortex/lifecycle/sessions/

# Lifecycle metrics aggregator (regenerated by reporter)
cortex/lifecycle/metrics.json

# Obsidian workspace config
.obsidian/

# Pytest temp directories
pytest-of-*/

# OS
.DS_Store

# Environment
.env
.env.*

# Lifecycle-archive sample-run slug list (transient; written by cortex-archive-sample-select)
.archive-sample.txt
.cortex-init
.cortex-init-backup/
